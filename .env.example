# ---------------------------------------------------------------------------
# Cornerstone RWA — environment configuration
# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- RPC endpoints (use your own provider keys: Alchemy, Infura, etc.) ------
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"
ARBITRUM_SEPOLIA_RPC_URL="https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY"
BASE_SEPOLIA_RPC_URL="https://base-sepolia.g.alchemy.com/v2/YOUR_KEY"

# --- Deployer key -----------------------------------------------------------
# Use a throwaway testnet account. Do NOT use a key that holds real funds.
PRIVATE_KEY="0xyour_test_private_key"

# --- Block explorer verification -------------------------------------------
ETHERSCAN_API_KEY="your_etherscan_api_key"

# --- Chainlink Functions -----------------------------------------------------
# Subscription ID from https://functions.chain.link
FUNCTIONS_SUBSCRIPTION_ID="0"

# --- Chainlink VRF -----------------------------------------------------------
# Subscription ID from https://vrf.chain.link (VRF 2.5)
VRF_SUBSCRIPTION_ID="0"

# --- AI / valuation provider (consumed inside the Functions source) ---------
# The secret is uploaded to Chainlink's DON, never placed on-chain.
AI_VALUATION_API_KEY="your_ai_or_avm_provider_key"
